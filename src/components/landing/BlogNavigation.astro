---
import { site } from "../../data/landing-content";

const links = [
  { name: "Home", href: "/#home" },
  { name: "Blog", href: "/#blog" },
  { name: "Projects", href: "/#projects" },
  { name: "About", href: "/#about" },
  { name: "Contact", href: "/#contact" },
];
---

<nav class="site-nav is-scrolled" data-nav>
  <div class="container nav-inner">
    <a href="/#home" class="brand">{site.title}</a>

    <ul class="nav-links">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class={link.name === "Blog" ? "is-active" : ""}>
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <button class="menu-toggle" type="button" aria-label="Toggle menu" data-menu-toggle>
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu>
    {
      links.map((link) => (
        <a href={link.href} class={link.name === "Blog" ? "is-active" : ""}>
          {link.name}
        </a>
      ))
    }
  </div>
</nav>

<script is:inline>
  const nav = document.querySelector("[data-nav]");
  const mobileMenu = nav?.querySelector("[data-mobile-menu]");
  const menuToggle = nav?.querySelector("[data-menu-toggle]");

  menuToggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("is-open");
  });
</script>
