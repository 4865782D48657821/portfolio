---
import BaseHead from '../../components/BaseHead.astro';
import BlogNavigation from '../../components/landing/BlogNavigation.astro';
import Footer from '../../components/landing/Footer.astro';
import '../../styles/landing.css';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.blog-page {
				padding-top: 4rem;
			}

			.blog-hero {
				padding: 5rem 0 3rem;
				background: linear-gradient(180deg, rgb(45 79 64 / 10%) 0%, rgb(248 249 241 / 65%) 100%);
				border-bottom: 1px solid rgb(197 160 89 / 20%);
			}

			.blog-hero .eyebrow {
				color: var(--forest);
			}

			.blog-hero p {
				margin-top: 1rem;
				max-width: 44rem;
				color: var(--muted);
				line-height: 1.7;
			}

			.blog-listing {
				padding: 3.5rem 0 6rem;
				background: #fff;
			}

			.blog-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.5rem;
			}

			.blog-card {
				border: 1px solid rgb(197 160 89 / 20%);
				border-radius: var(--radius);
				overflow: hidden;
				background: #fdfcfb;
			}

			.blog-card a {
				display: block;
				text-decoration: none;
			}

			.blog-image-wrap {
				position: relative;
			}

			.blog-image-wrap img {
				display: block;
				width: 100%;
				aspect-ratio: 16 / 10;
				object-fit: cover;
			}

			.blog-category {
				position: absolute;
				left: 0.75rem;
				top: 0.75rem;
				font-size: 0.7rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: #f8f9f1;
				background: rgb(45 79 64 / 85%);
				border-radius: 4px;
				padding: 0.3rem 0.5rem;
			}

			.blog-content {
				padding: 1rem;
			}

			.blog-meta {
				color: var(--muted);
				font-size: 0.76rem;
				display: flex;
				gap: 0.45rem;
			}

			.blog-title {
				margin-top: 0.7rem;
				font-size: clamp(1.5rem, 2.2vw, 2rem);
			}

			.blog-excerpt {
				margin-top: 0.8rem;
				color: var(--muted);
				line-height: 1.6;
			}

			.blog-link {
				display: inline-block;
				margin-top: 1rem;
				font-size: 0.9rem;
				color: var(--forest);
			}

			@media (max-width: 980px) {
				.blog-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<BlogNavigation />
		<main class="blog-page">
			<section class="blog-hero">
				<div class="container">
					<p class="eyebrow">Recent Writing</p>
					<h1>Blog</h1>
					<p>
						Essays on software architecture, systems design, and philosophy in engineering.
					</p>
				</div>
			</section>

			<section class="blog-listing">
				<div class="container">
					<div class="blog-grid">
					{
						posts.map((post) => (
							<article class="blog-card">
								<a href={`/blog/${post.id}/`}>
									<div class="blog-image-wrap">
										<img width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
										<span class="blog-category">{post.data.category ?? 'Essay'}</span>
									</div>
									<div class="blog-content">
										<p class="blog-meta">
											<time>
												{post.data.pubDate.toLocaleDateString('en-US', {
													month: 'long',
													day: 'numeric',
													year: 'numeric',
												})}
											</time>
											<span>·</span>
											<span>{post.data.readTime ?? '5 min'} read</span>
										</p>
										<h2 class="blog-title">{post.data.title}</h2>
										<p class="blog-excerpt">{post.data.description}</p>
										<span class="blog-link">Read More</span>
									</div>
								</a>
							</article>
						))
					}
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
