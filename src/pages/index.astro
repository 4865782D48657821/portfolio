---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/landing/Navigation.astro';
import Hero from '../components/landing/Hero.astro';
import FeaturedProjects from '../components/landing/FeaturedProjects.astro';
import LatestPosts from '../components/landing/LatestPosts.astro';
import About from '../components/landing/About.astro';
import Footer from '../components/landing/Footer.astro';
import '../styles/landing.css';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map((post) => ({
    id: post.id,
    title: post.data.title,
    excerpt: post.data.description,
    category: post.data.category ?? 'Essay',
    date: post.data.pubDate.toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    }),
    readTime: post.data.readTime ?? '5 min',
    imageUrl: post.data.heroImage,
    href: `/blog/${post.id}/`,
  }));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Navigation />
    <main>
      <Hero />
      <FeaturedProjects />
      <LatestPosts posts={latestPosts} />
      <About />
    </main>
    <Footer />
  </body>
</html>
