---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/landing/Navigation.astro';
import Hero from '../components/landing/Hero.astro';
import FeaturedProjects from '../components/landing/FeaturedProjects.astro';
import LatestPosts from '../components/landing/LatestPosts.astro';
import About from '../components/landing/About.astro';
import Footer from '../components/landing/Footer.astro';
import '../styles/landing.css';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Navigation />
    <main>
      <Hero />
      <FeaturedProjects />
      <LatestPosts />
      <About />
    </main>
    <Footer />
  </body>
</html>
